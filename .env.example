# Copy this file to .env and fill in your keys

# --- Domain / material wording (src/config/*.yaml) ---
# REVIEW_DOMAIN: which YAML pack to load (e.g. default). Long Chinese "material_domain_zh" lives in that file
# and is shared by extract_facts_by_chunk + build_dimensions_from_facts prompts (avoid duplicate drift).
# Parsed dimensions are written per proposal under src/data/parsed/<proposal_id>/ ; parallel reviews
# should use distinct proposal_id dirs or run one active project at a time.
#
# Question sets: generate_questions.py writes src/data/questions/<proposal_id>/generated_questions.json
# and mirrors the same JSON to src/data/config/question_sets/generated_questions.json. llm_answering.py
# defaults to the per-proposal path (matching API); CLI may omit --qs_file after a successful generate_questions run.
REVIEW_DOMAIN=default

# --- post_processing 权威词表 profile（src/config/postproc_authority/*.yaml）---
# 不设时：通用材料用 default；REVIEW_DOMAIN 为 biomedical / clinical / pharma 等时自动选 regulated_products。
# 也可显式覆盖：POSTPROC_AUTHORITY_PROFILE=regulated_products 或在 src/data/config/postproc/config.json 写 "authority_profile"。
# POSTPROC_AUTHORITY_PROFILE=

# LLM Provider — choose one: openai / deepseek / gemini
PROVIDER=openai

# OpenAI — use API model ids (e.g. gpt-5.2, gpt-5.2-chat-latest), not ChatGPT UI labels
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# DeepSeek (if using DeepSeek provider)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Gemini (if using Gemini provider)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Web Search APIs (optional)
GOOGLE_API_KEY=
GOOGLE_CX=
TAVILY_API_KEY=

# --- OCR / 扫描版商业类 PDF（prepare_proposal_text Stage 0；语言以 TESS_LANG 为准）---
# TESS_LANG: Tesseract 语言包。中英混排、以中文为主的扫描件常用 chi_sim+eng；纯英文材料可改为 eng。
# OCR_DPI: pdf2image 栅格化 DPI，用于「文本过少的页」的 OCR，以及整页送视觉模型前的栅格化。
#   竖排、小字、复杂表格、章封面较多时可试 260–300；纯电子 PDF 可保持 220；过高会更慢、更占内存。
# 表格/图中的数字以 OCR 结果写入 full_text 为准；全角/半角、千分位（如 1，234）尽量保留原文形态，
# 后续事实抽取与 verify_facts 请与 full_text 对齐，勿强行统一成另一种数字格式。
TESS_LANG=chi_sim+eng
OCR_DPI=220

# --- Fact verification (verify_facts Stage 1.5) ---
# VERIFY_USE_JIEBA: 1=use jieba for Chinese-heavy facts (better overlap vs 我司/全称混写); 0=regex only.
#   Requires optional package jieba (see requirements.txt). Numeric matching normalizes full-width digits/commas
#   and 万/亿/千万 amounts; facts should still mirror numerals in full_text when possible (see extract_facts prompt).
VERIFY_USE_JIEBA=1

# --- RAG 原文摘录（generate_questions + llm_answering；读 prepared/<pid>/pages.json 或 full_text.txt）---
RAG_TOP_K=5
RAG_MAX_CHARS=4500
RAG_PAGE_CHUNK_CHARS=1400
RAG_PAGE_CHUNK_STRIDE=900
RAG_WINDOW_CHARS=1400
RAG_WINDOW_STRIDE=700

# --- Question audit (generate_questions Stage 3, after LLM draft, before writing JSON) ---
# 默认全开：启发式 + LLM 审核；LLM 判定 remove 时默认从题单中删除（可用 QUESTION_AUDIT_AUTO_DROP=0 仅打标）。
QUESTION_AUDIT=1
QUESTION_AUDIT_LLM=1
QUESTION_AUDIT_AUTO_DROP=1

# Vision analysis for embedded images/charts (use a vision-capable API model, e.g. gpt-5.2)
# Set ENABLE_VISION=false to skip vision analysis entirely
VISION_MODEL=gpt-5.2
ENABLE_VISION=true

# Email delivery — choose ONE of the two options below:

# Option A: Resend (recommended — free, no domain/SMTP setup needed)
# Sign up at https://resend.com → API Keys → Create API Key
# Emails send from "onboarding@resend.dev" automatically (no domain verification needed)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Option B: SMTP (Gmail, Outlook, etc.)
# For Gmail: Google Account → Security → 2FA → App passwords → generate one
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_sender@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=Yangtze Delta <your_sender@gmail.com>
