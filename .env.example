# Copy this file to .env and fill in your keys

# LLM Provider — choose one: openai / deepseek / gemini
PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# DeepSeek (if using DeepSeek provider)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Gemini (if using Gemini provider)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Web Search APIs (optional)
GOOGLE_API_KEY=
GOOGLE_CX=
TAVILY_API_KEY=

# OCR language (default: chi_sim+eng for Chinese+English)
TESS_LANG=chi_sim+eng

# Vision analysis for embedded images/charts (requires a vision-capable model like gpt-4o)
# Set ENABLE_VISION=false to skip vision analysis entirely
VISION_MODEL=gpt-4o
ENABLE_VISION=true

# Email delivery — choose ONE of the two options below:

# Option A: Resend (recommended — free, no domain/SMTP setup needed)
# Sign up at https://resend.com → API Keys → Create API Key
# Emails send from "onboarding@resend.dev" automatically (no domain verification needed)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Option B: SMTP (Gmail, Outlook, etc.)
# For Gmail: Google Account → Security → 2FA → App passwords → generate one
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_sender@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=Yangtze Delta <your_sender@gmail.com>
